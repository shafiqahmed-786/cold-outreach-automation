# ===========================================================================
# Cold Outreach Pipeline – Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your real credentials.
#
# Windows:
#   copy .env.example .env
#
# Linux/macOS:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# The pipeline works in --mock mode without any credentials.
# ===========================================================================


# ---------------------------------------------------------------------------
# Stage 1 – Apollo.io (Similar Company Discovery)
# Replaces Ocean.io (approved alternative)
# ---------------------------------------------------------------------------
# Obtain at:
# https://app.apollo.io/#/settings/integrations/api
#
# Free plans may have stricter limits than paid plans.
APOLLO_API_KEY=your_apollo_api_key_here

# Confirmed Apollo API base URL
APOLLO_BASE_URL=https://api.apollo.io/api/v1

# Number of similar companies to discover
APOLLO_SIMILAR_LIMIT=10


# ---------------------------------------------------------------------------
# Stage 2 – Prospeo (Decision Maker Discovery + Email Enrichment)
# ---------------------------------------------------------------------------
# Prospeo now handles:
# - Decision maker discovery
# - LinkedIn profile discovery
# - Verified email enrichment
#
# Obtain API key from:
# https://prospeo.io
PROSPEO_API_KEY=your_prospeo_api_key_here

# Confirmed production base URL
PROSPEO_BASE_URL=https://api.prospeo.io

# Maximum contacts to search per company domain
# 25 = one page of results
PROSPEO_SEARCH_LIMIT=25


# ---------------------------------------------------------------------------
# Stage 3 – Brevo (Transactional Email Sending)
# ---------------------------------------------------------------------------
# Obtain API key from:
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# Confirmed Brevo API endpoint
BREVO_BASE_URL=https://api.brevo.com/v3

# Must be a verified sender in Brevo
BREVO_SENDER_NAME=Alex Carter
BREVO_SENDER_EMAIL=alex@yourcompany.com


# ---------------------------------------------------------------------------
# Pipeline Configuration
# ---------------------------------------------------------------------------

# State persistence
STATE_FILE=pipeline_state.json

# Logging
LOG_FILE=logs/pipeline.log

# Retry configuration
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# HTTP timeout (seconds)
REQUEST_TIMEOUT=30

# Concurrent outbound requests
CONCURRENT_REQUESTS=5