# ===========================================================================
# Cold Outreach Pipeline – Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your real credentials.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# The pipeline works in --mock mode without any of these credentials.
# ===========================================================================


# ---------------------------------------------------------------------------
# Stage 1 – Apollo.io (similar company discovery)
# Replaces Ocean.io. Approved by the assignment team.
# ---------------------------------------------------------------------------
# Obtain at: https://app.apollo.io/#/settings/integrations/api
# A free Apollo plan is sufficient; paid plans lift rate limits to 200 req/min.
APOLLO_API_KEY=your_apollo_api_key_here

# Confirmed base URL (docs.apollo.io, June 2026). Change only if Apollo
# releases a new API version.
APOLLO_BASE_URL=https://api.apollo.io/api/v1

# How many similar companies to return per pipeline run (default: 10).
# Apollo supports up to 100 per page; the service paginates automatically.
APOLLO_SIMILAR_LIMIT=10


# ---------------------------------------------------------------------------
# Stage 2 – Prospeo (decision maker / LinkedIn discovery)
# ---------------------------------------------------------------------------
# Obtain at: https://prospeo.io/api-key (dashboard → API)
PROSPEO_API_KEY=your_prospeo_api_key_here

# Base URL – change only if Prospeo updates their API version.
# TODO: Verify this is the correct production endpoint.
PROSPEO_BASE_URL=https://api.prospeo.io/v1


# ---------------------------------------------------------------------------
# Stage 3 – Eazyreach (LinkedIn → work email enrichment)
# ---------------------------------------------------------------------------
# Obtain at: https://eazyreach.io (dashboard → API settings)
EAZYREACH_API_KEY=your_eazyreach_api_key_here

# Base URL – change only if Eazyreach updates their API version.
# TODO: Verify this is the correct production endpoint.
EAZYREACH_BASE_URL=https://api.eazyreach.io/v1


# ---------------------------------------------------------------------------
# Stage 4 – Brevo (transactional email sending)
# ---------------------------------------------------------------------------
# Obtain at: https://app.brevo.com/settings/keys/api
# Use an SMTP & API key with "transactional emails" permission.
BREVO_API_KEY=your_brevo_api_key_here

# Brevo API base – this is a confirmed public endpoint.
BREVO_BASE_URL=https://api.brevo.com/v3

# Sender identity (must be a verified sender in your Brevo account)
BREVO_SENDER_NAME=Alex Carter
BREVO_SENDER_EMAIL=alex@yourcompany.com


# ---------------------------------------------------------------------------
# Pipeline tunables (all have safe defaults – override if needed)
# ---------------------------------------------------------------------------

# Path to the pipeline state file (relative to project root)
STATE_FILE=pipeline_state.json

# Path to the log file
LOG_FILE=logs/pipeline.log

# Maximum API retry attempts per request (includes first attempt)
MAX_RETRIES=3

# Base delay (seconds) for exponential back-off; actual sleep uses full jitter
RETRY_BASE_DELAY=1.0

# HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# Max concurrent outbound API requests (tune down if hitting rate limits)
CONCURRENT_REQUESTS=5
